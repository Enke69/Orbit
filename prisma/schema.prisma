generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  translations  Translation[]
  monthlyUsage  MonthlyUsage[]
  creditPurchases CreditPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Translation {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFileName String
  originalFilePath String            // Supabase storage path
  translatedFilePath String?         // Supabase storage path
  fileType         String            // "pdf" | "docx"
  sourceLanguage   String?           // auto-detected
  charCount        Int
  status           TranslationStatus @default(PENDING)
  errorMessage     String?
  outputFormat     String            @default("docx") // "pdf" | "docx"
  createdAt        DateTime          @default(now())
  completedAt      DateTime?
  expiresAt        DateTime?         // auto-delete after 7 days
}

enum TranslationStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model MonthlyUsage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       String   // "2026-05" format
  charsUsed   Int      @default(0)
  charsPaid   Int      @default(0)  // extra chars from top-ups
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, month])
}

model CreditPurchase {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  qpayInvoiceId String   @unique
  type          String   // "topup" | "subscription"
  charsGranted  Int
  amountMnt     Int      // amount in Mongolian Tögrög
  createdAt     DateTime @default(now())
}
